model RestaurantOutlet {
  id                    String              @id @default(uuid()) @db.Uuid
  tenant_id             String              @db.Uuid
  restaurant_id         String              @db.Uuid
  name                  String
  code                  String?
  address               String?
  gstin                 String?
  state_code            String?
  timezone              String              @default("Asia/Kolkata")
  default_language      LanguageCode        @default(EN)
  receipt_template      ReceiptTemplate     @default(MM80_STANDARD)
  variance_lock_amount  Decimal             @default(0) @db.Decimal(10, 2)
  variance_lock_percent Decimal             @default(0) @db.Decimal(5, 2)
  tax_pricing_mode      TaxPricingMode      @default(TAX_INCLUSIVE)
  tax_regime            TaxRegime           @default(GST_INDIA)
