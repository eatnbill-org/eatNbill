// ============================================================================
// KDS (Kitchen Display System) Settings
// ============================================================================

model KdsSettings {
  restaurant_id                      String     @id @db.Uuid
  restaurant                         Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  sound_enabled                      Boolean    @default(true)
  auto_clear_completed_after_seconds Int        @default(300)
  created_at                         DateTime   @default(now())
  updated_at                         DateTime   @updatedAt

  @@map("kds_settings")
}

// ============================================================================
// Table QR Codes
// ============================================================================

model TableQRCode {
  id          String          @id @default(uuid()) @db.Uuid
  table_id    String          @unique @db.Uuid
  menu_url    String
  qr_png_path String // Storage path for PNG
  qr_pdf_path String // Storage path for PDF
  qr_png_url  String? // Public/signed PNG URL
  qr_pdf_url  String? // Public/signed PDF URL
  created_at  DateTime        @default(now())
  updated_at  DateTime        @updatedAt
  table       RestaurantTable @relation(fields: [table_id], references: [id], onDelete: Cascade)

  @@index([table_id])
  @@map("table_qrcodes")
}

// ============================================================================
// Split Bill — divide one order payment across multiple payers
// ============================================================================

enum SplitType {
  EQUAL    // Split evenly N ways
  BY_ITEM  // Each payer is assigned specific items
  CUSTOM   // Custom amounts per payer
}

model BillSplit {
  id             String      @id @default(uuid()) @db.Uuid
  order_id       String      @db.Uuid
  split_type     SplitType   @default(EQUAL)
  payer_label    String      // "Guest 1", "Card ending 4242", etc.
  amount         Decimal     @db.Decimal(10, 2)
  payment_method String?
  payment_status String      @default("PENDING") // PENDING | PAID
  paid_at        DateTime?
  created_at     DateTime    @default(now())
  order          Order       @relation(fields: [order_id], references: [id], onDelete: Cascade)
  item_splits    OrderItemSplit[]

  @@index([order_id])
  @@map("bill_splits")
}

model OrderItemSplit {
  id            String     @id @default(uuid()) @db.Uuid
  split_id      String     @db.Uuid
  order_item_id String     @db.Uuid
  quantity      Int        @default(1)
  amount        Decimal    @db.Decimal(10, 2)
  split         BillSplit  @relation(fields: [split_id], references: [id], onDelete: Cascade)
  order_item    OrderItem  @relation(fields: [order_item_id], references: [id], onDelete: Cascade)

  @@index([split_id])
  @@map("order_item_splits")
}

// ============================================================================
// Inventory Management — Ingredients, Recipes (BOM), Stock Movements
// ============================================================================

model Ingredient {
  id              String          @id @default(uuid()) @db.Uuid
  tenant_id       String          @db.Uuid
  restaurant_id   String          @db.Uuid
  name            String
  unit            String          @default("pcs") // kg, g, L, ml, pcs, dozen
  current_stock   Decimal         @default(0) @db.Decimal(12, 3)
  reorder_level   Decimal?        @db.Decimal(12, 3)  // Alert threshold
  cost_per_unit   Decimal         @default(0) @db.Decimal(10, 4)
  category        String?
  is_active       Boolean         @default(true)
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt
  restaurant      Restaurant      @relation(fields: [restaurant_id], references: [id])
  recipe_lines           RecipeLine[]
  stock_movements        StockMovement[]
  purchase_order_lines   PurchaseOrderLine[]

  @@index([restaurant_id])
  @@map("ingredients")
}

model RecipeLine {
  id              String      @id @default(uuid()) @db.Uuid
  product_id      String      @db.Uuid
  ingredient_id   String      @db.Uuid
  quantity        Decimal     @db.Decimal(12, 4)  // Amount consumed per 1 unit of product
  product         Product     @relation(fields: [product_id], references: [id], onDelete: Cascade)
  ingredient      Ingredient  @relation(fields: [ingredient_id], references: [id])

  @@unique([product_id, ingredient_id])
  @@index([product_id])
  @@map("recipe_lines")
}

model StockMovement {
  id              String       @id @default(uuid()) @db.Uuid
  tenant_id       String       @db.Uuid
  restaurant_id   String       @db.Uuid
  ingredient_id   String       @db.Uuid
  type            String       // PURCHASE | CONSUMPTION | WASTE | ADJUSTMENT
  quantity        Decimal      @db.Decimal(12, 3) // Positive = in, Negative = out
  unit_cost       Decimal?     @db.Decimal(10, 4)
  notes           String?
  order_id        String?      @db.Uuid  // Set when type = CONSUMPTION (auto-deduct)
  created_by      String?      @db.Uuid  // RestaurantUser id
  created_at      DateTime     @default(now())
  ingredient      Ingredient   @relation(fields: [ingredient_id], references: [id])

  @@index([restaurant_id])
  @@index([ingredient_id])
  @@index([created_at])
  @@map("stock_movements")
}

// ============================================================================
// Supplier / Vendor Management with Purchase Orders
// ============================================================================

model Supplier {
  id              String          @id @default(uuid()) @db.Uuid
  tenant_id       String          @db.Uuid
  restaurant_id   String          @db.Uuid
  name            String
  contact_name    String?
  phone           String?
  email           String?
  address         String?
  gst_number      String?
  payment_terms   String?         // e.g. "Net 30", "COD"
  is_active       Boolean         @default(true)
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt
  restaurant      Restaurant      @relation(fields: [restaurant_id], references: [id])
  purchase_orders PurchaseOrder[]

  @@index([restaurant_id])
  @@map("suppliers")
}

model PurchaseOrder {
  id              String              @id @default(uuid()) @db.Uuid
  tenant_id       String              @db.Uuid
  restaurant_id   String              @db.Uuid
  supplier_id     String              @db.Uuid
  po_number       String
  status          String              @default("DRAFT")  // DRAFT | SENT | RECEIVED | CANCELLED
  order_date      DateTime            @default(now())
  expected_date   DateTime?
  received_date   DateTime?
  total_amount    Decimal             @default(0) @db.Decimal(10, 2)
  notes           String?
  created_at      DateTime            @default(now())
  updated_at      DateTime            @updatedAt
  supplier        Supplier            @relation(fields: [supplier_id], references: [id])
  lines           PurchaseOrderLine[]

  @@index([restaurant_id])
  @@index([supplier_id])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id              String         @id @default(uuid()) @db.Uuid
  po_id           String         @db.Uuid
  ingredient_id   String         @db.Uuid
  quantity        Decimal        @db.Decimal(12, 3)
  unit_cost       Decimal        @db.Decimal(10, 4)
  total_cost      Decimal        @db.Decimal(10, 2)
  received_qty    Decimal        @default(0) @db.Decimal(12, 3)
  purchase_order  PurchaseOrder  @relation(fields: [po_id], references: [id], onDelete: Cascade)
  ingredient      Ingredient     @relation(fields: [ingredient_id], references: [id])

  @@index([po_id])
  @@map("purchase_order_lines")
}
