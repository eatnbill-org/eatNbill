model GstInvoice {
  id                 String           @id @default(uuid()) @db.Uuid
  tenant_id          String           @db.Uuid
  restaurant_id      String           @db.Uuid
  outlet_id          String           @db.Uuid
  order_id           String           @unique @db.Uuid
  series_id          String           @db.Uuid
  invoice_number     String           @unique
  invoice_type       InvoiceType      @default(B2C)
  status             GstInvoiceStatus @default(DRAFT)
  buyer_name         String?
  buyer_gstin        String?
  buyer_state_code   String?
  seller_gstin       String?
  seller_state_code  String?
  is_tax_inclusive   Boolean          @default(true)
  subtotal_amount    Decimal          @default(0) @db.Decimal(10, 2)
  discount_amount    Decimal          @default(0) @db.Decimal(10, 2)
  taxable_amount     Decimal          @default(0) @db.Decimal(10, 2)
  cgst_amount        Decimal          @default(0) @db.Decimal(10, 2)
  sgst_amount        Decimal          @default(0) @db.Decimal(10, 2)
  igst_amount        Decimal          @default(0) @db.Decimal(10, 2)
  total_tax_amount   Decimal          @default(0) @db.Decimal(10, 2)
  grand_total_amount Decimal          @default(0) @db.Decimal(10, 2)
  irn_status         EInvoiceStatus   @default(NOT_APPLICABLE)
  irn                String?
  ack_no             String?
  ack_date           DateTime?
  signed_qr_payload  String?
  einvoice_provider  String?
  einvoice_error     Json?
  validated_at       DateTime?
  issued_at          DateTime?
  cancelled_at       DateTime?
  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt
  restaurant         Restaurant       @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  outlet             RestaurantOutlet @relation(fields: [outlet_id], references: [id], onDelete: Cascade)
  order              Order            @relation(fields: [order_id], references: [id], onDelete: Cascade)
  series             InvoiceSeries    @relation(fields: [series_id], references: [id], onDelete: Restrict)
  lines              GstInvoiceLine[]

  @@index([restaurant_id, created_at])
  @@index([outlet_id, invoice_number])
  @@index([irn_status])
  @@map("gst_invoices")
}

model GstInvoiceLine {
  id                    String     @id @default(uuid()) @db.Uuid
  invoice_id            String     @db.Uuid
  order_item_id         String?    @db.Uuid
  product_name          String
  hsn_sac               String?
  quantity              Int
  unit_price            Decimal    @db.Decimal(10, 2)
  taxable_amount        Decimal    @db.Decimal(10, 2)
  gst_rate_percent      Decimal    @db.Decimal(5, 2)
  cgst_amount           Decimal    @default(0) @db.Decimal(10, 2)
  sgst_amount           Decimal    @default(0) @db.Decimal(10, 2)
  igst_amount           Decimal    @default(0) @db.Decimal(10, 2)
  total_tax_amount      Decimal    @default(0) @db.Decimal(10, 2)
  line_total_amount     Decimal    @db.Decimal(10, 2)
  created_at            DateTime   @default(now())
  updated_at            DateTime   @updatedAt
  invoice               GstInvoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  @@index([invoice_id])
  @@index([order_item_id])
  @@map("gst_invoice_lines")
}

model RestaurantUser {
  id            String   @id @default(uuid()) @db.Uuid
  restaurant_id String   @db.Uuid
  user_id       String?  @db.Uuid // Optional for waiters (they use email/password instead)
  role          Role
  is_active     Boolean  @default(true)
  is_shared_login Boolean @default(false)
  created_at    DateTime @default(now())

  // Waiter-specific fields
  login_id               String? // Auto-generated like WTR-001 (deprecated, kept for compatibility)
  email                  String? // Waiter login email
  password_hash          String? // Hashed password for waiter login
  name                   String? // Display name
  phone                  String? // Contact number
  address                String? // Contact address
  profile_image_url      String? // Avatar URL
  salary                 Decimal? @db.Decimal(10, 2) // Monthly salary
  shift_detail           String? // Shift timing (e.g., "9 AM - 6 PM")
  completed_orders_count Int      @default(0) // Total completed+paid orders

  restaurant   Restaurant       @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  user         User?            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  orders       Order[]          // Orders handled by this waiter
  schedules    StaffSchedule[]
  time_entries StaffTimeEntry[]

  @@unique([restaurant_id, user_id])
  @@index([restaurant_id, role])
  @@index([login_id])
  @@index([email])
  @@index([user_id, is_active]) // ✅ Auth middleware lookup
  @@index([restaurant_id, is_active]) // ✅ Role checks
  @@map("restaurant_users")
}

model RestaurantHall {
  id            String            @id @default(uuid()) @db.Uuid
  restaurant_id String            @db.Uuid
  outlet_id     String?           @db.Uuid
  name          String
  is_ac         Boolean           @default(false)
  created_at    DateTime          @default(now())
  restaurant    Restaurant        @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  outlet        RestaurantOutlet? @relation(fields: [outlet_id], references: [id], onDelete: SetNull)
  tables        RestaurantTable[]
  orders        Order[]

  @@index([restaurant_id])
  @@index([outlet_id])
  @@map("restaurant_halls")
}

model RestaurantTable {
  id            String         @id @default(uuid()) @db.Uuid
  restaurant_id String         @db.Uuid
  outlet_id     String?        @db.Uuid
  hall_id       String         @db.Uuid
  table_number  String
  seats         Int
  is_active     Boolean        @default(true)
  table_status  TableStatus    @default(AVAILABLE)
  // Floor plan positioning (optional — null = not placed on floor plan)
  x_position    Int?           // Grid column position (0-based)
  y_position    Int?           // Grid row position (0-based)
  shape         String?        // RECTANGLE | CIRCLE (default RECTANGLE)
  created_at    DateTime       @default(now())
  restaurant    Restaurant     @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  outlet        RestaurantOutlet? @relation(fields: [outlet_id], references: [id], onDelete: SetNull)
  hall          RestaurantHall @relation(fields: [hall_id], references: [id], onDelete: Cascade)
  orders        Order[]
  reservations  TableReservation[]
  qr_code       TableQRCode?

  @@unique([restaurant_id, table_number])
  @@index([restaurant_id])
  @@index([outlet_id])
  @@index([hall_id])
  @@map("restaurant_tables")
}

model TableReservation {
  id                 String            @id @default(uuid()) @db.Uuid
  tenant_id          String            @db.Uuid
  restaurant_id      String            @db.Uuid
  outlet_id          String?           @db.Uuid
  table_id           String            @db.Uuid
  customer_name      String
  customer_phone     String?
  customer_email     String?
  party_size         Int
  reserved_from      DateTime
  reserved_to        DateTime
  notes              String?
  status             ReservationStatus @default(BOOKED)
  created_by_user_id String?           @db.Uuid
  created_at         DateTime          @default(now())
  updated_at         DateTime          @updatedAt
  cancelled_at       DateTime?
  restaurant         Restaurant          @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  outlet             RestaurantOutlet?   @relation(fields: [outlet_id], references: [id], onDelete: SetNull)
  table              RestaurantTable     @relation(fields: [table_id], references: [id], onDelete: Cascade)
  deposits           ReservationDeposit[]

  @@index([restaurant_id, reserved_from])
  @@index([outlet_id, reserved_from])
  @@index([restaurant_id, status])
  @@index([table_id, reserved_from, reserved_to])
  @@map("table_reservations")
}

// ============================================================================
// Reservation Deposit (Pre-authorization / No-show Protection)
