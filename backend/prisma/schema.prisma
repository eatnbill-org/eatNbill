  updated_at         DateTime     @updatedAt
  user               User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  default_outlet     RestaurantOutlet? @relation(fields: [default_outlet_id], references: [id], onDelete: SetNull)

  @@index([tenant_id])
  @@index([default_outlet_id])
  @@map("user_preferences")
}

model DayEndClosure {
  id                  String      @id @default(uuid()) @db.Uuid
  tenant_id           String      @db.Uuid
  restaurant_id       String      @db.Uuid
  outlet_id           String      @db.Uuid
  business_date       DateTime    @db.Date
  expected_cash       Decimal     @default(0) @db.Decimal(10, 2)
  expected_card       Decimal     @default(0) @db.Decimal(10, 2)
  expected_upi        Decimal     @default(0) @db.Decimal(10, 2)
  expected_aggregator Decimal     @default(0) @db.Decimal(10, 2)
  actual_cash         Decimal     @default(0) @db.Decimal(10, 2)
  actual_card         Decimal     @default(0) @db.Decimal(10, 2)
  actual_upi          Decimal     @default(0) @db.Decimal(10, 2)
  actual_aggregator   Decimal     @default(0) @db.Decimal(10, 2)
  variance_cash       Decimal     @default(0) @db.Decimal(10, 2)
  variance_card       Decimal     @default(0) @db.Decimal(10, 2)
  variance_upi        Decimal     @default(0) @db.Decimal(10, 2)
  variance_aggregator Decimal     @default(0) @db.Decimal(10, 2)
  expected_total      Decimal     @default(0) @db.Decimal(10, 2)
  actual_total        Decimal     @default(0) @db.Decimal(10, 2)
  variance_total      Decimal     @default(0) @db.Decimal(10, 2)
  variance_percent    Decimal     @default(0) @db.Decimal(5, 2)
  status              DayEndStatus @default(OPEN)
  closed_by_user_id   String?     @db.Uuid
  closed_at           DateTime?
  locked_at           DateTime?
  lock_reason         String?
  unlocked_by_user_id String?     @db.Uuid
  unlocked_at         DateTime?
  unlock_reason       String?
  created_at          DateTime    @default(now())
  updated_at          DateTime    @updatedAt
  restaurant          Restaurant  @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  outlet              RestaurantOutlet @relation(fields: [outlet_id], references: [id], onDelete: Cascade)
  variance_events     DayEndVarianceEvent[]
  unlock_events       DayEndUnlockEvent[]

  @@unique([outlet_id, business_date])
  @@index([restaurant_id, business_date])
  @@index([outlet_id, status])
  @@map("day_end_closures")
}

model DayEndVarianceEvent {
  id             String                 @id @default(uuid()) @db.Uuid
  day_end_id     String                 @db.Uuid
  event_type     DayEndVarianceEventType
  metadata       Json?
  created_by_user_id String?            @db.Uuid
  created_at     DateTime               @default(now())
  day_end        DayEndClosure          @relation(fields: [day_end_id], references: [id], onDelete: Cascade)

  @@index([day_end_id])
  @@index([created_at])
  @@map("day_end_variance_events")
}

model DayEndUnlockEvent {
  id             String        @id @default(uuid()) @db.Uuid
  day_end_id     String        @db.Uuid
  reason         String
  metadata       Json?
  unlocked_by_user_id String?  @db.Uuid
  created_at     DateTime      @default(now())
  day_end        DayEndClosure @relation(fields: [day_end_id], references: [id], onDelete: Cascade)

  @@index([day_end_id])
  @@index([created_at])
  @@map("day_end_unlock_events")
}

model ExportJob {
  id               String         @id @default(uuid()) @db.Uuid
  tenant_id        String         @db.Uuid
