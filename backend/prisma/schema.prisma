// ============================================================================
// Loyalty Program
// ============================================================================

model LoyaltyProgram {
  id                      String              @id @default(uuid()) @db.Uuid
  restaurant_id           String              @unique @db.Uuid
  name                    String              @default("Rewards Program")
  points_per_spend_unit   Decimal             @default(1) @db.Decimal(10, 2)  // e.g., 1 point per ₹10 spent
  spend_unit              Decimal             @default(10) @db.Decimal(10, 2) // ₹10 per unit
  redemption_rate         Decimal             @default(1) @db.Decimal(10, 2)  // ₹1 discount per point
  min_points_to_redeem    Int                 @default(10)
  is_active               Boolean             @default(true)
  created_at              DateTime            @default(now())
  updated_at              DateTime            @updatedAt
  restaurant              Restaurant          @relation(fields: [restaurant_id], references: [id])
  customer_loyalty        CustomerLoyalty[]

  @@map("loyalty_programs")
}

model CustomerLoyalty {
  id                String         @id @default(uuid()) @db.Uuid
  tenant_id         String         @db.Uuid
  restaurant_id     String         @db.Uuid
  customer_id       String         @db.Uuid
  program_id        String         @db.Uuid
  points_balance    Int            @default(0)
  total_earned      Int            @default(0)
  total_redeemed    Int            @default(0)
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt
  customer          Customer       @relation(fields: [customer_id], references: [id])
  program           LoyaltyProgram @relation(fields: [program_id], references: [id])
  transactions      LoyaltyTransaction[]

  @@unique([customer_id, program_id])
  @@index([restaurant_id])
  @@map("customer_loyalty")
}

model LoyaltyTransaction {
  id                String          @id @default(uuid()) @db.Uuid
  customer_loyalty_id String        @db.Uuid
  order_id          String?         @db.Uuid
  points            Int             // Positive = earned, negative = redeemed
  type              String          // EARNED | REDEEMED | ADJUSTED
  notes             String?
  created_at        DateTime        @default(now())
  customer_loyalty  CustomerLoyalty @relation(fields: [customer_loyalty_id], references: [id])

  @@index([customer_loyalty_id])
  @@map("loyalty_transactions")
}

